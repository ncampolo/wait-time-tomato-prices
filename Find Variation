# Variance summary by port (in hours, pre-log)
port_summary <- melt(
  wait_wide,
  id.vars = "week_start_date",
  measure.vars = port_vars,   # "laredo", "nogales", "otay_mesa"
  variable.name = "port",
  value.name = "avg_wait_hr"
