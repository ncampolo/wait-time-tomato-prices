  mean_hr   = mean(avg_wait_hr, na.rm = TRUE),
  sd_hr     = sd(avg_wait_hr, na.rm = TRUE),
  cv        = sd(avg_wait_hr, na.rm = TRUE) / mean(avg_wait_hr, na.rm = TRUE),
  min_hr    = min(avg_wait_hr, na.rm = TRUE),
  max_hr    = max(avg_wait_hr, na.rm = TRUE),
  n_weeks   = sum(!is.na(avg_wait_hr))
), by = port]

